@startuml secuencia-step-simulacion
!theme plain
skinparam backgroundColor transparent
skinparam shadowing false
skinparam sequenceMessageAlign center

title Secuencia de un paso de simulación (step)

actor Usuario
participant "SimulationControls" as Controls
participant "useTrafficSimulation\n(hook)" as Hook
participant "QLearningAgent" as Agent
participant "TrafficGridEnv" as Env
participant "React\n(re-render)" as React

Usuario -> Controls : click "Avanzar un paso"
Controls -> Hook : step()
activate Hook

Hook -> Agent : chooseAction(state)
activate Agent
Agent --> Hook : action (epsilon-greedy)
deactivate Agent

Hook -> Env : step(action)
activate Env
Env --> Hook : { nextState, reward,\nisAnomaly, isCongestion, done }
deactivate Env

Hook -> Agent : update(state, action, reward, nextState)
activate Agent
Agent -> Agent : actualiza qTable\n(ecuación de Bellman)
deactivate Agent

Hook -> Hook : setGrid / setPosition /\nsetTotalReward / setHistory

alt done == true
  Hook -> Env : reset() (nuevo grid, dron a (0,0))
  Hook -> Hook : setEpisodeCount++, setEpisodeHistory
end

Hook --> React : nuevo estado expuesto\n(grid, position, qTable, history)
deactivate Hook

React -> React : re-renderiza\nTrafficGridMap, DecisionPanel,\nQTablePanel, RewardChart

@enduml
